# goose-agent-template — Environment Variables
# =============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Only one provider block should be uncommented at a time.

# === Provider (required) ===
GOOSE_PROVIDER=anthropic
GOOSE_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...

# === OpenAI ===
# GOOSE_PROVIDER=openai
# GOOSE_MODEL=gpt-4o
# OPENAI_API_KEY=sk-...

# === Azure OpenAI (verify provider string against goosed binary) ===
# GOOSE_PROVIDER=openai
# GOOSE_MODEL=gpt-4o
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name
# AZURE_API_VERSION=2024-02-15-preview

# === Google (Gemini via API key) ===
# GOOSE_PROVIDER=google
# GOOSE_MODEL=gemini-2.0-flash
# GOOGLE_API_KEY=...

# === GCP Vertex AI ===
# GOOSE_PROVIDER=gcp-vertex
# GOOSE_MODEL=gemini-2.0-flash
# GCP_PROJECT_ID=your-project
# GCP_REGION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# === AWS Bedrock ===
# GOOSE_PROVIDER=bedrock
# GOOSE_MODEL=anthropic.claude-sonnet-4-6-20250514-v1:0
# (Uses AWS credentials from environment or instance profile)

# === OpenRouter ===
# GOOSE_PROVIDER=openrouter
# GOOSE_MODEL=anthropic/claude-sonnet-4-6
# OPENROUTER_API_KEY=...

# === Ollama (local) ===
# GOOSE_PROVIDER=ollama
# GOOSE_MODEL=llama3

# === Databricks ===
# GOOSE_PROVIDER=databricks
# GOOSE_MODEL=databricks-meta-llama-3-1-70b-instruct
# (Uses Databricks credentials from environment)

# === Runtime ===
# GOOSE_MODE=auto  # Default is auto. Uncomment to override. Options: auto | smart_approve | approve | chat
GOOSE_MAX_TURNS=1000
GOOSE_HOST=0.0.0.0
GOOSE_PORT=3000
GOOSE_TLS=false

# === Model Parameters (optional) ===
# GOOSE_CONTEXT_LIMIT=200000
# GOOSE_MAX_TOKENS=8192
# GOOSE_TEMPERATURE=0.7
# GOOSE_AUTO_COMPACT_THRESHOLD=0.8  # Compact conversation at this % of context window (default: 0.8 = 80%)

# === Container ===
GOOSE_DISABLE_KEYRING=1
GOOSE_TELEMETRY_OFF=1

# === Server Auth ===
# GOOSE_SERVER__SECRET_KEY=your-secret  # Auto-generated if not set. Set explicitly when callers need to authenticate to the REST API.

# === MCP Server URIs (override for k8s — Compose uses defaults) ===
# MCP_HELLO_WORLD_URI=http://mcp-hello-world.goose-agent.svc.cluster.local:8080/mcp

# === Observability (optional) ===
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_SERVICE_NAME=goose-agent
# RUST_LOG=info
