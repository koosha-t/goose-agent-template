# Kubernetes Secrets for Goose Agent
# ===================================
# Copy this file to secrets.yaml, fill in base64-encoded values, then apply:
#   cp secrets.yaml.example secrets.yaml
#   kubectl apply -f secrets.yaml
#
# Encode values: echo -n 'your-value' | base64

apiVersion: v1
kind: Secret
metadata:
  name: goose-secrets
  namespace: goose-agent
type: Opaque
data:
  # Required: LLM provider credentials
  GOOSE_PROVIDER: YW50aHJvcGlj                  # anthropic
  GOOSE_MODEL: Y2xhdWRlLXNvbm5ldC00LTY=         # claude-sonnet-4-6
  ANTHROPIC_API_KEY: c2stYW50LS4uLg==             # sk-ant-...

  # Optional: server auth secret (auto-generated if not set)
  # GOOSE_SERVER__SECRET_KEY: eW91ci1zZWNyZXQ=    # your-secret
